# Copy to the repository root as `.env` and fill every value.
# Hardhat loads `../../.env` (repo root) then `packages/hardhat/.env` (overrides).
# AgoraFrontEnd (Next) inlines `NEXT_PUBLIC_*` from the repo root `.env` at build time.

# -----------------------------------------------------------------------------
# BNB Smart Chain — RPC (use MegaNode / BSCTrace-style endpoints)
# -----------------------------------------------------------------------------
# Deprecated BSCScan *REST* APIs are being replaced by JSON-RPC on MegaNode (BSCTrace).
# Put your MegaNode endpoint here, e.g. https://bsc-mainnet.nodereal.io/v1/<YOUR_KEY>
# Migration: https://www.bnbchain.org/en/blog/migration-guide-bscscan-api-to-bsctrace-api-via-meganode
BSC_RPC_URL=
BSC_TESTNET_RPC_URL=

# -----------------------------------------------------------------------------
# Contract verification (`yarn verify`) — NOT the same as BSCTrace RPC
# -----------------------------------------------------------------------------
# MegaNode does not host “verify Solidity source” — that still goes through the unified
# Etherscan API v2 flow used by @nomicfoundation/hardhat-verify when apiKey is a string.
# Create one key: https://etherscan.io/apis (works for BSC mainnet + testnet via chainid).
ETHERSCAN_V2_API_KEY=

# Deployer private key used by hardhat deploy scripts (0x...)
DEPLOYER_PRIVATE_KEY=

# Optional Hardhat fork (any archive JSON-RPC URL, e.g. MegaNode BSC). Off by default.
# HARDHAT_FORKING_ENABLED=true
# HARDHAT_FORK_RPC_URL=

# -----------------------------------------------------------------------------
# Next.js — must be prefixed with NEXT_PUBLIC_ to reach the browser
# -----------------------------------------------------------------------------
# WalletConnect Cloud — enables the "WalletConnect" button on /trade (wagmi)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# BSC testnet JSON-RPC URL (MegaNode testnet or other provider)
NEXT_PUBLIC_BSC_TESTNET_RPC_URL=

# Used by `packages/AgoraFrontEnd` for reads + wallet RPC (falls back to chain default if unset)
NEXT_PUBLIC_RPC_URL=

# Python FastAPI (`uvicorn app.main:app --port 8001`)
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8001

# -----------------------------------------------------------------------------
# Hardhat → generated contract files (optional overrides; paths relative to packages/hardhat/)
# -----------------------------------------------------------------------------
# AGORA_FRONTEND_CONTRACTS_DIR=../AgoraFrontEnd/contracts
# AGORA_BACKEND_CONTRACTS_DIR=../backend/app/contracts

# -----------------------------------------------------------------------------
# FastAPI CORS — comma-separated browser origins. If unset, allows local dev URLs only.
# Production example: CORS_ALLOW_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com
# CORS_ALLOW_ORIGINS=

# -----------------------------------------------------------------------------
# Backend object storage — auto uses GCS when GOOGLE_APPLICATION_CREDENTIALS file exists, else local disk.
# STORAGE_BACKEND=auto
# STORAGE_BACKEND=gcs
# STORAGE_BACKEND=local
# AGORA_LOCAL_DATA_DIR=/absolute/path   (default: packages/backend/data)

# Optional: BNB Smart Chain mainnet RPC if you add `chains.bsc` to `scaffold.config.ts`
NEXT_PUBLIC_BSC_RPC_URL=

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_IPFS_BUILD=true
# PORT=3000

# -----------------------------------------------------------------------------
# Python backend (reads repo root `.env`)
# -----------------------------------------------------------------------------
GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=
RPC_URL=
MANAGER_ADDRESS=
EXCHANGE_ADDRESS=
FACTORY_ADDRESS=
FORWARDER_ADDRESS=
# Gas-only hot wallet: submits ERC2771Forwarder.execute for user meta-txs. NO on-chain admin role.
# MUST use a different private key than RESOLVER_PRIVATE_KEY (backend refuses to start if they match).
RELAYER_PRIVATE_KEY=
# On-chain resolver address key: submits PredictionMarketManager.resolve after admin confirm.
# Same trust boundary as ops/admin (often same key as DEPLOYER in dev deploys) — never the relayer key.
RESOLVER_PRIVATE_KEY=
# Owner key for MarketFactory createEvent/createMarket (defaults to DEPLOYER_PRIVATE_KEY)
FACTORY_OWNER_PRIVATE_KEY=
# Python relay integration script (`yarn hardhat:integration:gas-sponsored`)
BACKEND_URL=http://127.0.0.1:8000
FMP_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Yahoo scraper: optional headless browser (cookies + JS).
#   python3 -m pip install playwright
#   python3 -m playwright install chromium
# YAHOO_USE_PLAYWRIGHT=1
# If requests gets 4xx/5xx, retry once with Playwright:
# YAHOO_PLAYWRIGHT_FALLBACK=1
# Polite pause before each Yahoo request (seconds; helps some rate limits)
# YAHOO_REQUEST_DELAY_SECONDS=1.5
# YAHOO_PLAYWRIGHT_TIMEOUT_MS=45000
SCHEDULER_POLL_INTERVAL_SECONDS=120
EVENT_LISTENER_POLL_INTERVAL_SECONDS=15
GCS_BATCH_INTERVAL_SECONDS=60

# -----------------------------------------------------------------------------
# Testnet wallet sandbox (max 6 wallets) for integration exercises
# -----------------------------------------------------------------------------
# `yarn hardhat:mint:test-wallets` — mint mUSDT to TEST_WALLET_* (uses deployer signer).
# `yarn hardhat:test:bsc-testnet` — Mocha on bscTestnet: needs BSC_TESTNET_RPC_URL, MOCK_USDT_ADDRESS,
# RELAYER_PRIVATE_KEY (gas for mint), MANAGER_ADDRESS, EXCHANGE_ADDRESS, and all TEST_WALLET_* below.
MOCK_USDT_ADDRESS=
MOCK_USDT_MINT_PER_WALLET=1000
TEST_WALLET_1_ADDRESS=
TEST_WALLET_2_ADDRESS=
TEST_WALLET_3_ADDRESS=
TEST_WALLET_4_ADDRESS=
TEST_WALLET_5_ADDRESS=
TEST_WALLET_6_ADDRESS=
TEST_WALLET_1_PRIVATE_KEY=
TEST_WALLET_2_PRIVATE_KEY=
TEST_WALLET_3_PRIVATE_KEY=
TEST_WALLET_4_PRIVATE_KEY=
TEST_WALLET_5_PRIVATE_KEY=
TEST_WALLET_6_PRIVATE_KEY=
